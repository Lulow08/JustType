<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.lulow.justtype.controller.MenuController">

    <AnchorPane
            fx:id="rootPane"
            prefWidth="640" prefHeight="360"
            minWidth="640" minHeight="360"
            styleClass="root-pane">

        <HBox
                fx:id="titleDisplay"
                alignment="CENTER"
                AnchorPane.topAnchor="78"
                AnchorPane.leftAnchor="0"
                AnchorPane.rightAnchor="0">

            <Label
                    fx:id="titleLabel"
                    text="JustType"
                    styleClass="char-normal, char-white"/>

        </HBox>

        <VBox
                fx:id="menuBox"
                alignment="CENTER"
                spacing="6"
                AnchorPane.topAnchor="198"
                AnchorPane.leftAnchor="0"
                AnchorPane.rightAnchor="0">

            <HBox fx:id="newGameRow" alignment="CENTER" spacing="8">
                <Label fx:id="newGameIndicator" text="◆" styleClass="menu-indicator"/>
                <Label fx:id="newGameLabel"     text="New Game" styleClass="menu-item-active"/>
            </HBox>

            <HBox fx:id="exitRow" alignment="CENTER" spacing="8">
                <Label fx:id="exitIndicator" text="◆" styleClass="menu-indicator"/>
                <Label fx:id="exitLabel"     text="Exit" styleClass="menu-item-inactive"/>
            </HBox>

        </VBox>

        <Label
                fx:id="hintLabel"
                text="press 󰁝 󰁅 to move · ENTER to select"
                styleClass="lose-hint"
                alignment="CENTER"
                maxWidth="Infinity"
                AnchorPane.bottomAnchor="16"
                AnchorPane.leftAnchor="0"
                AnchorPane.rightAnchor="0"/>

    </AnchorPane>

</StackPane>